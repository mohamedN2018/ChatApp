# =============================================================================
# ChatApp environment template. Copy to `.env` and adjust for your setup.
#   cp .env.example .env
# In production, set every secret to a strong unique value and never commit it.
# =============================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# --- Database (Postgres) ---
DATABASE_URL=postgres://chatapp:chatapp@postgres:5432/chatapp
DB_CONN_MAX_AGE=60

# --- Redis (cache / channels / celery use separate logical DBs) ---
REDIS_URL=redis://redis:6379/0
CHANNEL_LAYERS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3

# --- JWT ---
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# --- MinIO / S3 object storage ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=chatapp-media
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# --- CORS / Frontend ---
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# --- Email (production SMTP; dev prints to console) ---
DEFAULT_FROM_EMAIL=ChatApp <no-reply@chatapp.local>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

# --- Production-only security/monitoring ---
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
CSRF_TRUSTED_ORIGINS=
SENTRY_DSN=
