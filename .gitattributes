# Normalize line endings. Text files are stored as LF in the repo so the same
# bytes run in Linux containers regardless of the contributor's OS.
* text=auto eol=lf

# Files that MUST be LF (executed inside Linux containers).
*.sh        text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Windows-only scripts keep CRLF.
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary assets — never normalize.
*.mo   binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.mp3  binary
*.mp4  binary
*.wav  binary
*.ogg  binary
*.pdf  binary
